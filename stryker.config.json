{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress", "json"],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js",
    "enableFindRelatedTests": false
  },
  "commandRunner": {
    "command": "npm test -- --testPathPattern=app.test.js"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "app.js",
    "!jest.config.js",
    "!stryker.config.json"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70 
  }
}
