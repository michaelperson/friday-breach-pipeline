{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress", "json"],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "mutate": [   
    "app/**/*.test.js",
    "!jest.config.js",
    "!stryker.config.json"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70 
  }
}
